{
  "name": "senstive-check-service",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --target bun --minify-whitespace --minify-syntax --outfile ./dist/index.js src/index.ts",
    "start": "bun ./dist/index.js",
    "build:binary": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts",
    "build:docker": "bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile server src/index.ts"
  },
  "dependencies": {
    "elysia": "latest"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
